pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	bullets={} enemies={} stars={}
	x=64 y=100
	dx=0 dy=0
	cd=0
	sp=true
	score=0
end

function _update()
	local ac=0.5
	local fr=0.7
	if (btn(⬅️)) dx-=ac
	if (btn(➡️)) dx+=ac
	if (btn(⬆️)) dy-=ac 
	if (btn(⬇️)) dy+=ac
	if (btn(❎) and cd==0) then
		add(bullets,{
			x=x+rnd(4)-2,
			y=y
		})
		cd=4
	elseif (cd>0) then
	 cd-=1
	end
	if (btn(🅾️)) then
		add(enemies,{
			x=rnd(120),
			y=rnd(10)+8,
			sprite=23+rnd(6),
			speed=rnd(3)-1.5
		})
	end
	sp=not sp

	x+=dx y+=dy	dx*=fr dy*=fr
	x=max(min(x,120),0)
	y=max(min(y,120),0)

	-- enemy movement
	for enemy in all(enemies) do
		enemy.x+=enemy.speed
		if enemy.x>120 or enemy.x<0 then
			enemy.speed*=-1 -- other direction
		end
	end

	-- collision detection
	for bullet in all(bullets) do
		if bullet.y>-8 then
			bullet.y-=3
			for enemy in all(enemies) do
				if
					bullet.x<enemy.x+4 and bullet.x+4>enemy.x and
					bullet.y<enemy.y+2 and bullet.y+2>enemy.y then
					del(bullets,bullet)
					del(enemies,enemy)
					score+=1
					break
				end
			end
		else
			del(bullets,bullet)
		end
	end

	-- stars
	for star in all(stars) do
		if star.y<128 then
			star.y+=star.speed
		else
			del(stars,star)
		end
	end
	while #stars<10 do
		add(stars,{
			x=rnd(120),
			y=rnd(120)-120,
			speed=rnd(4)+2
		})
	end
end

function _draw()
	cls()
	
	for star in all(stars) do
		pset(star.x,star.y,5)
	end
	
	for bullet in all(bullets) do
		spr(33,bullet.x,bullet.y,1,1,bullet.y%2==1)
	end

	for enemy in all(enemies) do
		spr(enemy.sprite,enemy.x,enemy.y,1,1,enemy.y%2==1)
	end

	local sprite=abs(dx)<.2 and 2 or 4
	local flipped=dx<0
	local flame=abs(dy)<.2 and 0 or sgn(dy)
	spr(6,x,y+6-flame,1,1,sp)
	spr(sprite,x,y,1,1,flipped)
	
	local score_text=tostr(score)
	print(score_text,127-#score_text*4,10)

-- rectfill(0,0,100,8,0)
-- print(stat(1),0,0,1)
-- print((7+flame*2).." "..flame,40,0,1)
end

