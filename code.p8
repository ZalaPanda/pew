pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	bullets={} enemies={}
	x=64 y=100
	dx=0 dy=0
	c=0
	f=0
end

function _update()
 local ac=0.5
 local fr=0.7
	if (btn(⬅️)) dx-=ac
	if (btn(➡️)) dx+=ac
	if (btn(⬆️)) dy-=ac 
	if (btn(⬇️)) dy+=ac
	if (btn(❎) and c==0) add(bullets,{x+rnd(4)-2,y}) c=4
	if (btn(🅾️)) add(enemies,{rnd(120),rnd(10),23+rnd(5),rnd(3)-1.5})
	if (c>0) c-=1
	f=(f+1)%2

	x+=dx y+=dy	dx*=fr dy*=fr
	x=max(min(x,120),0)
	y=max(min(y,120),0)

	-- movement
	for ee=#enemies,1,-1 do
		local e=enemies[ee]
		e[1]+=e[4]
		if (e[1]>120 or e[1]<0) e[4]*=-1
	end
 	
	-- collision detection
	for eb=#bullets,1,-1 do
		local b=bullets[eb]
		for ee=#enemies,1,-1 do
			local e=enemies[ee]
			if b[1]<e[1]+8 and b[1]+2>e[1] and b[2]<e[2]+8 and b[2]+2>e[2] then
				del(bullets,b)
				del(enemies,e)
				break
			end
		end
	end
end

function _draw()
--	for i=0,2000 do
--		pset(rnd(128),rnd(128),0)
--	end
 cls()
	for b in all(bullets) do
  if b[2]<8 then
   del(bullets,b)
  else
   b[2]-=3
   spr(33,b[1],b[2],1,1,b[2]%2==1)
  end
 end

 for e in all(enemies) do
  spr(e[3],e[1],e[2],1,1,e[2]%2==1)
 end

 local s=abs(dx)<0.2 and 4 or 3
 local f=dx<0
 rectfill(x-2,y,x+8,y+8,0)
 spr(s,x,y,1,1,f)
-- rectfill(0,0,100,8,0)
-- print(stat(1),0,0,1)
-- print(s.." "..dx,40,0,1)
end

